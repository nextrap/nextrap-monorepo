{
    "name": "ntl-accordion",
    "version": "1.0.0",
    "contributions": {
        "html": {
            "elements": [
                {
                    "name": "ntl-accordion",
                    "description": "Accordion layout container for embedded FAQ/detail sections.",
                    "slots": [{ "name": "default", "description": "Direct sections or ntl-accordion-item elements" }],
                    "attributes": [
                        {
                            "name": "exclusive",
                            "type": "boolean",
                            "description": "Close other items when one item opens."
                        },
                        {
                            "name": "initial-open-index",
                            "type": "number",
                            "description": "Zero-based index of the initially opened item."
                        },
                        {
                            "name": "marker-position",
                            "type": "start | end",
                            "description": "Marker position propagated to child items."
                        },
                        {
                            "name": "marker-icon",
                            "type": "chevron | plus",
                            "description": "Marker icon variant propagated to child items."
                        }
                    ]
                },
                {
                    "name": "ntl-accordion-item",
                    "description": "Single accordion item based on a native details element.",
                    "slots": [
                        { "name": "title", "description": "Item summary/title" },
                        { "name": "default", "description": "Item content" }
                    ],
                    "attributes": [
                        { "name": "open", "type": "boolean", "description": "Open state of the item." },
                        {
                            "name": "marker-position",
                            "type": "start | end",
                            "description": "Marker position for this item."
                        },
                        {
                            "name": "marker-icon",
                            "type": "chevron | plus",
                            "description": "Marker icon variant for this item."
                        }
                    ]
                }
            ]
        },
        "css": {
            "classes": [
                { "name": "default", "description": "Default visual styling from default.scss." },
                { "name": "details-end", "description": "Render summary after content." },
                { "name": "marker-start", "description": "Render marker before title." },
                { "name": "marker-plus", "description": "Use plus/minus marker icons." }
            ],
            "parts": [
                { "name": "accordion" },
                { "name": "details" },
                { "name": "summary" },
                { "name": "title" },
                { "name": "marker" },
                { "name": "content" }
            ]
        }
    }
}
